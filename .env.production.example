# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION / shared-hosting (cPanel) environment template.
#
# IMPORTANT:
#   • This is only an EXAMPLE. Copy it to ".env" ON THE SERVER and fill in real
#     values:   cp .env.production.example .env
#   • The real ".env" must NEVER be committed to git (it is in .gitignore).
#   • Generate APP_KEY once on the server:   php artisan key:generate
#   • These drivers use the filesystem (no cache/sessions/queue DB tables needed),
#     which avoids "table not found" errors on first deploy.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME="KSA Embassy File System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://embassy-app.heavenlymatch.net

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database (set these from your cPanel MySQL® Databases) ───────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=heavwzih_ksa_embassy
DB_USERNAME=heavwzih_ksa_user
DB_PASSWORD=

# ─── Session / Cache / Queue (filesystem-safe for shared hosting) ────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Mail (use your cPanel email account) ────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mail.heavenlymatch.net
MAIL_PORT=587
MAIL_USERNAME=noreply@heavenlymatch.net
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@heavenlymatch.net"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
